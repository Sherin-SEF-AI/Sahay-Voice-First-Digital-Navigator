# Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Gemini Models
GEMINI_COMPUTER_USE_MODEL=gemini-2.5-computer-use-preview-10-2025
GEMINI_VOICE_MODEL=gemini-live-2.5-flash-native-audio

# Google AI Studio API Key (needed for Computer Use model)
GOOGLE_API_KEY=

# Firestore
FIRESTORE_COLLECTION=sahay_tasks

# Application
APP_PORT=8080
SCREEN_WIDTH=1440
SCREEN_HEIGHT=900
DEFAULT_LANGUAGE=hi
BROWSER_HEADLESS=true
